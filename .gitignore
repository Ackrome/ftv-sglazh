# Python bytecode and runtime caches
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.python-version

# Virtual environments
.venv/
venv/
env/
ENV/

# Python packaging/build outputs
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Test, coverage, and type-check caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Numba/JIT caches
*.nbc
*.nbi

# Application-generated artifacts and local job state
artifacts/
*.sqlite
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# Large local datasets and generated scientific outputs
*.nc
*.nc4
*.h5
*.hdf5
*.zarr/

# Graphify generated knowledge graph
graphify-out/

# Generated document extraction/render folders
docx-media/
docx-render/

# Generated aggregate/context dumps
repomix-output.xml

# Local environment files and secrets
.env
.env.*
!.env.example
*.local

# Docker/local compose overrides
docker-compose.override.yml

# IDE/editor metadata
.idea/
.vscode/
*.swp
*.swo
*~

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Office temporary lock files
~$*.docx
~$*.xlsx
~$*.pptx
